rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == "vansh61924@gmail.com"; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.keys().size() >= 4 &&
             data.uid == request.auth.uid &&
             data.role in ['passenger', 'rider'] &&
             data.email is string &&
             data.email.size() <= 100 &&
             data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      incoming().uid == existing().uid &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().role == existing().role &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email', 'vehicleNumber', 'vehicleType']);
      
      match /paymentMethods/{cardId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --- Ride Validation ---
    function isValidRide(data) {
      return data.keys().hasAll(['rideId', 'userId', 'pickup', 'destination', 'price', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.price is number && data.price > 0 &&
             data.status in ['pending', 'active', 'completed', 'cancelled'] &&
             data.createdAt == request.time;
    }

    match /rides/{rideId} {
      allow get: if (isSignedIn() && existing().userId == request.auth.uid) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidRide(incoming());
      allow update: if (isSignedIn() && isOwner(existing().userId)) || isAdmin() && (
                        incoming().userId == existing().userId &&
                        incoming().createdAt == existing().createdAt &&
                        isValidRide(incoming()) && (
                          // Action: Update Status
                          incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                          existing().status != 'completed' && existing().status != 'cancelled'
                        )
                      );
    }

    // --- Transaction Validation ---
    function isValidTransaction(data) {
      return data.keys().hasAll(['transactionId', 'userId', 'amount', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['success', 'failed'] &&
             data.createdAt == request.time;
    }

    match /transactions/{transactionId} {
      allow get: if (isSignedIn() && existing().userId == request.auth.uid) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidTransaction(incoming());
      // No updates or deletes for transactions
    }
  }
}
